#!/usr/bin/env python3
"""
Record external outcome memory for MiniMadMax custom Ollama models.

This does not teach the model weights. It records durable operational memory
that a tool-enabled wrapper or Codex session can read and inject later.
"""

import argparse
import json
from datetime import datetime, timezone
from pathlib import Path


SCRIPT_ROOT = Path(__file__).resolve().parents[1]
if (SCRIPT_ROOT / "models" / "minimadmax" / "system.md").exists():
    ROOT = SCRIPT_ROOT
else:
    ROOT = Path("/root/ai-lab/MiniMadMax")
DATA_DIR = ROOT / "data"
OUTCOMES = DATA_DIR / "outcomes.jsonl"
LEARNED = DATA_DIR / "learned.json"


def load_learned() -> dict:
    if LEARNED.exists():
        return json.loads(LEARNED.read_text())
    return {
        "version": 1,
        "session_count": 0,
        "task_counts": {},
        "outcome_counts": {},
        "model_counts": {},
        "notes": [],
    }


def save_learned(data: dict) -> None:
    LEARNED.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")


def record(args: argparse.Namespace) -> None:
    DATA_DIR.mkdir(parents=True, exist_ok=True)
    entry = {
        "timestamp": datetime.now(timezone.utc).isoformat(),
        "model": args.model,
        "task": args.task,
        "outcome": args.outcome,
        "quality": args.quality,
        "note": args.note,
    }
    with OUTCOMES.open("a", encoding="utf-8") as fh:
        fh.write(json.dumps(entry, sort_keys=True) + "\n")

    learned = load_learned()
    learned["session_count"] = learned.get("session_count", 0) + 1
    learned.setdefault("task_counts", {})
    learned.setdefault("outcome_counts", {})
    learned.setdefault("model_counts", {})
    learned["task_counts"][args.task] = learned["task_counts"].get(args.task, 0) + 1
    learned["outcome_counts"][args.outcome] = learned["outcome_counts"].get(args.outcome, 0) + 1
    learned["model_counts"][args.model] = learned["model_counts"].get(args.model, 0) + 1
    if args.note:
        learned.setdefault("notes", []).append({
            "timestamp": entry["timestamp"],
            "model": args.model,
            "task": args.task,
            "outcome": args.outcome,
            "quality": args.quality,
            "note": args.note,
        })
        learned["notes"] = learned["notes"][-50:]
    save_learned(learned)
    print(json.dumps(entry, indent=2, sort_keys=True))


def status(_: argparse.Namespace) -> None:
    print(json.dumps(load_learned(), indent=2, sort_keys=True))


def main() -> None:
    parser = argparse.ArgumentParser(description="Record model outcome memory")
    sub = parser.add_subparsers(dest="command", required=True)

    rec = sub.add_parser("record", help="Record one model outcome")
    rec.add_argument("--model", required=True, choices=["minimadmax", "codex-nemotron", "other"])
    rec.add_argument("--task", default="general")
    rec.add_argument("--outcome", required=True, choices=["success", "failure", "mixed", "note"])
    rec.add_argument("--quality", type=int, default=3, choices=range(1, 6))
    rec.add_argument("--note", default="")
    rec.set_defaults(func=record)

    stat = sub.add_parser("status", help="Show learned outcome summary")
    stat.set_defaults(func=status)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
